# ══════════════════════════════════════════════════════════════
#  FA2M — Configuration Apache (.htaccess)
#  Sécurité, HTTPS, Headers, Protection admin
# ══════════════════════════════════════════════════════════════

Options -Indexes
ServerSignature Off

# ── 1. Forcer HTTPS ────────────────────────────────────────────
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ── 2. WWW → non-WWW (optionnel, choisir un seul) ─────────────
# RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
# RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

# ── 3. Headers de sécurité ─────────────────────────────────────
<IfModule mod_headers.c>
    # Empêche le clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"
    # Empêche le MIME-sniffing
    Header always set X-Content-Type-Options "nosniff"
    # Active la protection XSS du navigateur
    Header always set X-XSS-Protection "1; mode=block"
    # Referrer minimal
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    # Force HTTPS pendant 1 an (HSTS)
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    # Content Security Policy
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://fonts.gstatic.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://images.unsplash.com https://placehold.co; connect-src 'self'; frame-ancestors 'self';"
    # Permissions Policy (désactiver fonctionnalités inutiles)
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"
    # Supprimer header X-Powered-By
    Header unset X-Powered-By
    Header always unset X-Powered-By
</IfModule>

# ── 4. Protection du fichier admin ─────────────────────────────
# Option A : Restreindre l'accès admin par IP (décommente et mets ton IP)
# <Files "admin.html">
#     Order deny,allow
#     Deny from all
#     Allow from TON.IP.ICI
# </Files>

# Option B : Changer le nom du fichier admin (recommandé)
# Renomme admin.html en quelque chose d'unique comme :
# gestion-fa2m-secret.html
# et mets à jour les liens dans index.html / sidebar

# ── 5. Protéger les fichiers sensibles ─────────────────────────
<FilesMatch "\.(htaccess|htpasswd|env|log|sh|sql|bak|config|ini|lock|json)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Autoriser uniquement les fichiers nécessaires
<FilesMatch "\.(html|css|js|png|jpg|jpeg|webp|gif|svg|ico|woff|woff2|ttf|eot)$">
    Order allow,deny
    Allow from all
</FilesMatch>

# ── 6. Compression GZIP (performance) ─────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml
    AddOutputFilterByType DEFLATE text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE font/ttf font/otf
</IfModule>

# ── 7. Cache navigateur (performance) ─────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/html "access plus 1 hour"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/jpeg "access plus 6 months"
    ExpiresByType image/png "access plus 6 months"
    ExpiresByType image/webp "access plus 6 months"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
</IfModule>

# ── 8. Empêcher l'accès direct aux dossiers ───────────────────
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_URI} !^/$
RewriteRule ^(.+)/$ /$1 [L,R=301]

# ── 9. Page d'erreur personnalisée ────────────────────────────
ErrorDocument 403 /index.html
ErrorDocument 404 /index.html

# ── 10. Bloquer les bots malveillants connus ──────────────────
<IfModule mod_rewrite.c>
    RewriteCond %{HTTP_USER_AGENT} (havij|sqlmap|nikto|nessus|openvas|masscan|zgrab) [NC]
    RewriteRule .* - [F,L]
</IfModule>
