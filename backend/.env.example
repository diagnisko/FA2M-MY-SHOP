# ─── Serveur ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Sécurité (CHANGEZ EN PRODUCTION !) ────────────────────────
# Générez une clé aléatoire sécurisée d'au moins 32 caractères
JWT_SECRET=votre_clé_secrète_très_longue_et_aléatoire_min_32_chars
JWT_EXPIRES_IN=24h

# ─── Base de données ────────────────────────────────────────────
# Pour Vercel: SQLite persiste dans /tmp mais est réinitialisé à chaque déploiement
# Envisaging une migration vers PostgreSQL pour la production
DB_PATH=./data/fa2m.db

# ─── PostgreSQL (Production recommandé) ─────────────────────────
# Pour Vercel Postgres : https://vercel.com/integrations/postgres
# PG_URL=postgres://user:password@host:port/dbname?sslmode=require
PG_URL=postgres://postgres.ksvugozutiooqsvbttig:lxMIVkNCleCJsWOm@aws-1-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require&supa=base-pooler.x

# ─── Compte Administrateur (CHANGEZ EN PRODUCTION !) ───────────
ADMIN_USERNAME=votre_nom_utilisateur_admin_sécurisé
ADMIN_PASSWORD=votre_mot_de_passe_admin_très_sécurisé

# ─── CORS — Origines autorisées (séparées par virgule) ─────────
# Remplacez avec votre domaine Vercel: https://votreprojet.vercel.app
FRONTEND_ORIGINS=https://votreprojet.vercel.app,https://www.votreprojet.sn

# ─── URLs de l'application ──────────────────────────────────────
# Pour Vercel, utilisez: https://votreprojet.vercel.app
APP_URL=https://votreprojet.vercel.app
API_URL=https://votreprojet.vercel.app

# ─── Wave (https://wave.com/developers) ────────────────────────
# Créez un compte marchand Wave pour obtenir ces clés
WAVE_API_KEY=
WAVE_WEBHOOK_SECRET=

# ─── Orange Money (https://developer.orange.com) ───────────────
# Créez un compte développeur Orange pour obtenir ces clés
OM_CLIENT_ID=
OM_CLIENT_SECRET=
OM_MERCHANT_KEY=
OM_COUNTRY=sn

# ─── Configuration Boutique ─────────────────────────────────────
SHOP_PHONE=221781332323
SHOP_NAME=FA2M
